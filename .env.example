# ── LLM Providers ──────────────────────────────────────────────────────────────
# At least one key is required.  The agent tries providers in this order:
#   Groq → OpenAI → Google Gemini
# If a provider is rate-limited the next one is tried automatically.
#
# Groq  (recommended — free tier, very fast)
#   https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# OpenAI  (fallback #2)
#   https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Google Gemini  (fallback #3)
#   https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here
# Note: GEMINI_API_KEY also works; GOOGLE_API_KEY takes priority if both are set.
# GEMINI_API_KEY=your-gemini-api-key-here


# ── Service Security ────────────────────────────────────────────────────────────
# Shared secret between the agent and the MCP server.
# The agent sends this as X-API-Key on every internal request.
# The MCP server rejects requests that don't present the correct key.
#
# Generate a value:  openssl rand -hex 32
# Leave EMPTY to run in unauthenticated dev-mode (key check skipped).
MCP_API_KEY=

# Optional key to protect /diagnostics and /diagnostics/live-trace.
# These expose raw LLM output — gate them before any public deployment.
#
# Generate a value:  openssl rand -hex 32
# Leave EMPTY for open access (dev-mode).
DIAGNOSTICS_API_KEY=


# ── Service URLs (optional overrides) ──────────────────────────────────────────
# Defaults work for local dev and Docker Compose.
# MCP_SERVER_URL=http://localhost:8001


# ── LLM Model Overrides (optional) ─────────────────────────────────────────────
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENAI_MODEL=gpt-4.1-mini
# GOOGLE_MODEL=gemini-2.0-flash
